#!/bin/bash
# chiron: install and verify a portable operating-discipline kit for coding
# agents (Claude Code hooks + doctrine, Codex AGENTS.md).
set -euo pipefail

VERSION="0.2.0"

# Kit source resolution: installed package first, then git checkout layout.
resolve_kit() {
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -d /usr/share/chiron/kit/doctrine ]; then
        printf '/usr/share/chiron/kit'
    elif [ -d "$script_dir/../doctrine" ]; then
        (cd "$script_dir/.." && pwd)
    else
        echo "chiron: cannot locate kit files (looked in /usr/share/chiron/kit and repo layout)" >&2
        return 1
    fi
}

usage() {
    cat <<'HELP_EOF'
chiron: a mentor kit for coding agents

Installs an operating doctrine plus mechanical enforcement hooks so a
coding agent (Claude Code, Codex CLI) verifies before acting, cannot
bypass checks, and cannot claim unverified completion.

USAGE
  chiron install [--project DIR | --user] [--claude] [--codex]
  chiron doctor  [--project DIR | --user]
  chiron --help | --version

COMMANDS
  install   Copy the kit and wire it into the target harness.
            --project DIR  install into DIR (default: current directory)
            --user         install into ~/.claude for all projects (Claude only)
            --claude       wire Claude Code hooks + settings (default)
            --codex        write AGENTS.md + .chiron/doctrine.md for Codex CLI
  doctor    Verify an install end-to-end: files present, settings wired,
            and every hook fires with the expected verdict on synthetic
            input (guard denies a --no-verify, stop-verify blocks an
            unverified stop, session-start writes its canary).

FILES
  Claude project install:  DIR/.claude/chiron/ plus hooks merged into
                           DIR/.claude/settings.json (backup written first)
  Claude user install:     ~/.claude/chiron/ plus ~/.claude/settings.json
  Codex install:           DIR/AGENTS.md and DIR/.chiron/doctrine.md
  Project checklist:       DIR/.chiron/checklist.md (optional, user-owned,
                           NOT created at install time; when present it is
                           inlined into every turn's reminder)

DISCLAIMER
  This software modifies agent-harness configuration files and injects
  instructions into model sessions. It is provided AS IS, WITHOUT WARRANTY
  OF ANY KIND. You alone are responsible for reviewing what it installs
  and for anything the configured agent does. The author is not liable
  for any damage arising from its use. If you do not accept these terms,
  do not install or run this software. Full text: see the project README.
HELP_EOF
}

log()  { printf 'chiron: %s\n' "$*"; }
fail() { printf 'chiron: ERROR: %s\n' "$*" >&2; exit 1; }

require_python() {
    command -v python3 >/dev/null 2>&1 || fail "python3 is required"
}

# Copy kit payload into <base>/.claude/chiron/.
copy_claude_kit() {
    local kit="$1" dest="$2"
    mkdir -p "$dest/hooks"
    install -m 0644 "$kit/doctrine/doctrine.md" "$dest/doctrine.md"
    install -m 0644 "$kit/doctrine/reminder.md" "$dest/reminder.md"
    install -m 0755 "$kit"/adapters/claude-code/hooks/*.sh "$dest/hooks/"
}

# Merge the hooks fragment into a settings.json, idempotently.
merge_settings() {
    local kit="$1" settings="$2" hook_base="$3"
    CHIRON_KIT="$kit" CHIRON_SETTINGS="$settings" CHIRON_HOOK_BASE="$hook_base" \
    python3 <<'PYEOF'
import json, os, shutil, sys

kit = os.environ["CHIRON_KIT"]
settings_path = os.environ["CHIRON_SETTINGS"]
hook_base = os.environ["CHIRON_HOOK_BASE"]

with open(os.path.join(kit, "adapters/claude-code/settings-fragment.json"),
          encoding="utf-8") as f:
    fragment = json.load(f)

settings = {}
if os.path.isfile(settings_path):
    shutil.copy2(settings_path, settings_path + ".chiron-bak")
    with open(settings_path, encoding="utf-8") as f:
        settings = json.load(f)

hooks = settings.setdefault("hooks", {})
changed = False
for event, entries in fragment["hooks"].items():
    existing = hooks.setdefault(event, [])
    already = any(
        "/chiron/hooks/" in h.get("command", "")
        for entry in existing for h in entry.get("hooks", [])
    )
    if already:
        continue
    for entry in entries:
        entry = json.loads(json.dumps(entry))
        for h in entry.get("hooks", []):
            h["command"] = h["command"].replace(
                "$CLAUDE_PROJECT_DIR/.claude/chiron", hook_base)
        existing.append(entry)
        changed = True

os.makedirs(os.path.dirname(settings_path), exist_ok=True)
with open(settings_path, "w", encoding="utf-8") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")
print("merged" if changed else "already wired", file=sys.stderr)
PYEOF
}

install_claude_project() {
    local kit="$1" dir="$2"
    [ -d "$dir" ] || fail "no such directory: $dir"
    copy_claude_kit "$kit" "$dir/.claude/chiron"
    # The literal string is intended: the harness expands it at hook time.
    # shellcheck disable=SC2016
    merge_settings "$kit" "$dir/.claude/settings.json" \
        '$CLAUDE_PROJECT_DIR/.claude/chiron'
    log "Claude Code project install done: $dir/.claude/chiron"
    log "hooks wired in $dir/.claude/settings.json (backup: settings.json.chiron-bak)"
}

install_claude_user() {
    local kit="$1"
    copy_claude_kit "$kit" "$HOME/.claude/chiron"
    merge_settings "$kit" "$HOME/.claude/settings.json" "$HOME/.claude/chiron"
    log "Claude Code user install done: ~/.claude/chiron (all projects)"
}

install_codex() {
    local kit="$1" dir="$2"
    [ -d "$dir" ] || fail "no such directory: $dir"
    mkdir -p "$dir/.chiron"
    install -m 0644 "$kit/doctrine/doctrine.md" "$dir/.chiron/doctrine.md"
    if [ -f "$dir/AGENTS.md" ]; then
        if grep -q 'chiron' "$dir/AGENTS.md"; then
            log "AGENTS.md already references chiron; leaving it untouched"
        else
            log "AGENTS.md exists; NOT overwriting."
            log "Append the template yourself: $kit/adapters/codex/AGENTS.md"
        fi
    else
        install -m 0644 "$kit/adapters/codex/AGENTS.md" "$dir/AGENTS.md"
        log "wrote $dir/AGENTS.md"
    fi
    log "Codex install done: $dir/.chiron/doctrine.md"
}

# doctor: verify files, wiring, and live hook behavior on synthetic input.
doctor() {
    local base="$1" settings="$2" label="$3"
    local kit_dir="$base/chiron" failures=0

    check() { # check <name> <0|1 ok>
        if [ "$2" -eq 0 ]; then
            printf '  PASS  %s\n' "$1"
        else
            printf '  FAIL  %s\n' "$1"
            failures=$((failures + 1))
        fi
    }
    check_that() { # check_that <name> <command...>
        local name="$1"; shift
        if "$@"; then check "$name" 0; else check "$name" 1; fi
    }

    log "doctor: checking $label install"

    [ -f "$kit_dir/doctrine.md" ]; check "doctrine.md present" $?
    [ -f "$kit_dir/reminder.md" ]; check "reminder.md present" $?
    local h missing=0
    for h in session-start turn-reminder guard stop-verify; do
        [ -x "$kit_dir/hooks/$h.sh" ] || missing=1
    done
    check "all four hooks present and executable" "$missing"
    if [ -f "$settings" ] && grep -q '/chiron/hooks/' "$settings"; then
        check "settings.json references chiron hooks" 0
    else
        check "settings.json references chiron hooks" 1
    fi
    command -v python3 >/dev/null 2>&1; check "python3 available" $?

    if [ "$missing" -eq 0 ] && command -v python3 >/dev/null 2>&1; then
        local tmp out
        tmp="$(mktemp -d)"

        CLAUDE_PROJECT_DIR="$tmp" "$kit_dir/hooks/session-start.sh" \
            </dev/null >"$tmp/ss.json" 2>/dev/null || true
        check_that "session-start writes canary" test -f "$tmp/.chiron-canary"
        python3 -c "import json;json.load(open('$tmp/ss.json'))" 2>/dev/null
        check "session-start emits valid JSON" $?

        CLAUDE_PROJECT_DIR="$tmp" "$kit_dir/hooks/turn-reminder.sh" \
            </dev/null >"$tmp/tr.json" 2>/dev/null || true
        CHIRON_TR="$tmp/tr.json" CHIRON_REM="$kit_dir/reminder.md" python3 - <<'PYEOF' 2>/dev/null
import json, os, sys
out = json.load(open(os.environ["CHIRON_TR"], encoding="utf-8"))
text = out["hookSpecificOutput"]["additionalContext"]
want = open(os.environ["CHIRON_REM"], encoding="utf-8").read().strip()
sys.exit(0 if text == want else 1)
PYEOF
        check "turn-reminder text matches reminder.md" $?

        mkdir -p "$tmp/.chiron"
        printf -- '- CHIRON-DOCTOR-CHECKLIST-MARKER step\n' \
            > "$tmp/.chiron/checklist.md"
        CLAUDE_PROJECT_DIR="$tmp" "$kit_dir/hooks/turn-reminder.sh" \
            </dev/null >"$tmp/tr-cl.json" 2>/dev/null || true
        CHIRON_TR="$tmp/tr-cl.json" CHIRON_REM="$kit_dir/reminder.md" \
            python3 - <<'PYEOF' 2>/dev/null
import json, os, sys
out = json.load(open(os.environ["CHIRON_TR"], encoding="utf-8"))
text = out["hookSpecificOutput"]["additionalContext"]
want = open(os.environ["CHIRON_REM"], encoding="utf-8").read().strip()
sys.exit(0 if text.startswith(want)
         and "CHIRON-DOCTOR-CHECKLIST-MARKER" in text else 1)
PYEOF
        check "turn-reminder inlines the project checklist" $?

        python3 -c "open('$tmp/.chiron/checklist.md','w').write('x' * 9000)" \
            2>/dev/null || true
        CLAUDE_PROJECT_DIR="$tmp" "$kit_dir/hooks/turn-reminder.sh" \
            </dev/null >"$tmp/tr-big.json" 2>/dev/null || true
        CHIRON_TR="$tmp/tr-big.json" CHIRON_REM="$kit_dir/reminder.md" \
            python3 - <<'PYEOF' 2>/dev/null
import json, os, sys
out = json.load(open(os.environ["CHIRON_TR"], encoding="utf-8"))
text = out["hookSpecificOutput"]["additionalContext"]
want = open(os.environ["CHIRON_REM"], encoding="utf-8").read().strip()
sys.exit(0 if text.startswith(want)
         and "too large to inline" in text
         and "xxxx" not in text else 1)
PYEOF
        check "turn-reminder degrades an oversized checklist to a pointer" $?

        rm -f "$tmp/.chiron/checklist.md"
        ln -s /etc/hostname "$tmp/.chiron/checklist.md" 2>/dev/null || true
        CLAUDE_PROJECT_DIR="$tmp" "$kit_dir/hooks/turn-reminder.sh" \
            </dev/null >"$tmp/tr-sym.json" 2>/dev/null || true
        CHIRON_TR="$tmp/tr-sym.json" CHIRON_REM="$kit_dir/reminder.md" \
            python3 - <<'PYEOF' 2>/dev/null
import json, os, sys
out = json.load(open(os.environ["CHIRON_TR"], encoding="utf-8"))
text = out["hookSpecificOutput"]["additionalContext"]
want = open(os.environ["CHIRON_REM"], encoding="utf-8").read().strip()
sys.exit(0 if text == want else 1)
PYEOF
        check "turn-reminder ignores a checklist symlinked outside the project" $?
        rm -rf "$tmp/.chiron"

        out=$(printf '{"tool_name":"Bash","tool_input":{"command":"git commit --no-verify -m x"}}' \
            | CLAUDE_PROJECT_DIR="$tmp" "$kit_dir/hooks/guard.sh" 2>/dev/null) || true
        printf '%s' "$out" | grep -q '"permissionDecision": *"deny"'
        check "guard denies a --no-verify command" $?

        out=$(printf '{"tool_name":"Bash","tool_input":{"command":"ls -la"}}' \
            | CLAUDE_PROJECT_DIR="$tmp" "$kit_dir/hooks/guard.sh" 2>/dev/null) || true
        check_that "guard stays silent on a harmless command" test -z "$out"

        printf '{"type":"assistant","message":{"content":[{"type":"tool_use","name":"Edit","input":{"file_path":"src/app.py","old_string":"a","new_string":"b"}}]}}\n' \
            > "$tmp/transcript.jsonl"
        out=$(printf '{"stop_hook_active":false,"transcript_path":"%s"}' "$tmp/transcript.jsonl" \
            | "$kit_dir/hooks/stop-verify.sh" 2>/dev/null) || true
        printf '%s' "$out" | grep -q '"decision": *"block"'
        check "stop-verify blocks an unverified code edit" $?

        printf '{"type":"assistant","message":{"content":[{"type":"tool_use","name":"Bash","input":{"command":"pytest tests/"}}]}}\n' \
            >> "$tmp/transcript.jsonl"
        out=$(printf '{"stop_hook_active":false,"transcript_path":"%s"}' "$tmp/transcript.jsonl" \
            | "$kit_dir/hooks/stop-verify.sh" 2>/dev/null) || true
        [ -z "$out" ]; check "stop-verify passes once tests were run" $?

        rm -rf "$tmp"
    fi

    if [ -f "${CLAUDE_PROJECT_DIR:-$PWD}/.chiron-waiver" ]; then
        printf '  WARN  .chiron-waiver present (guard is in waiver mode)\n'
    fi

    if [ "$failures" -gt 0 ]; then
        fail "doctor: $failures check(s) failed"
    fi
    log "doctor: all checks passed"
}

main() {
    local cmd="${1:-}"
    [ -n "$cmd" ] || { usage; exit 1; }
    shift || true

    local scope="project" dir="$PWD" do_claude=0 do_codex=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --project) scope="project"; dir="${2:?--project needs DIR}"; shift 2 ;;
            --user)    scope="user"; shift ;;
            --claude)  do_claude=1; shift ;;
            --codex)   do_codex=1; shift ;;
            *) fail "unknown option: $1" ;;
        esac
    done
    [ "$do_claude" -eq 1 ] || [ "$do_codex" -eq 1 ] || do_claude=1

    case "$cmd" in
        install)
            require_python
            local kit; kit="$(resolve_kit)"
            if [ "$do_claude" -eq 1 ]; then
                if [ "$scope" = "user" ]; then
                    install_claude_user "$kit"
                else
                    install_claude_project "$kit" "$dir"
                fi
            fi
            if [ "$do_codex" -eq 1 ]; then
                [ "$scope" = "user" ] && fail "--codex supports --project installs only"
                install_codex "$kit" "$dir"
            fi
            ;;
        doctor)
            if [ "$scope" = "user" ]; then
                doctor "$HOME/.claude" "$HOME/.claude/settings.json" "user"
            else
                doctor "$dir/.claude" "$dir/.claude/settings.json" "project ($dir)"
            fi
            ;;
        --help|-h|help) usage ;;
        --version) printf 'chiron %s\n' "$VERSION" ;;
        *) usage; exit 1 ;;
    esac
}

main "$@"
